# ── Site URL ──
# Set to your production domain (e.g. https://yourdomain.com)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Google OAuth (Drive API + Sign-In) ──
# Create credentials at https://console.cloud.google.com/apis/credentials
# Desktop application type (supports localhost redirects)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Drive root folder ID where portfolio media is stored
GOOGLE_DRIVE_FOLDER_ID=

# ── Google Sign-In (Web client) ──
# Only needed if using the GIS popup flow (currently unused — Desktop client is used for sign-in)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ── Admin ──
# Email allowed to access the admin panel (/cmdpanel)
ADMIN_EMAIL=your.email@gmail.com

# Optional: IP address allowed to access /cmdpanel (leave empty to allow any IP)
ADMIN_IP=

# Session encryption secret (generate with: openssl rand -hex 32)
SESSION_SECRET=

# ── Two-Factor Auth (TOTP) ──
# Generate at: /cmdpanel/setup-2fa after logging in
TOTP_SECRET=
TOTP_ENABLED=true
